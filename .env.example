# Copy to .env and fill in. Validated by src/lib/env.ts (zod) at startup.
# Env matrix (local / staging / prod): docs/technical-design.md §7.

# Local Docker Postgres (pnpm db:up). Staging/prod use the Neon branch URL.
DATABASE_URL=postgres://paulitakes:paulitakes@localhost:5434/paulitakes

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Per-environment OAuth clients (never share between envs).
# Optional until the clients exist — a provider is disabled unless both
# its id and secret are set.
# Google: https://console.cloud.google.com/apis/credentials
#   redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Discord: https://discord.com/developers/applications
#   redirect URI: {BETTER_AUTH_URL}/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Vercel AI Gateway key — LOCAL ONLY. Deployed envs use Vercel OIDC.
AI_GATEWAY_API_KEY=

# Shared secret for the cron-job.org revalidation endpoint (min 16 chars).
CRON_SECRET=

# Seed for the rotating daily analytics salt (min 16 chars, no PII stored).
ANALYTICS_SALT_SEED=

# Comment rate limits (defaults shown).
COMMENT_RATE_LIMIT_PER_MINUTE=3
COMMENT_RATE_LIMIT_PER_HOUR=30
